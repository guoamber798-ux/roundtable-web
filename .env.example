# Right Code 中转站（Claude）
OPENAI_API_KEY=sk-your-rightcode-key-here
DEFAULT_MODEL=claude-sonnet-4-5-20250929
API_PROVIDER=anthropic
ANTHROPIC_BASE_URL=https://www.right.codes/claude

# 试用模式：false = 无需登录，直接领晤（自己测试时用）
AUTH_REQUIRED=false

RATE_LIMIT_PER_HOUR=20

# JWT 登录密钥（生产环境务必改成随机长字符串）
JWT_SECRET=change-me-to-random-secret

# 管理员密钥（用于创建口令，见下方 curl 示例）
ADMIN_SECRET=your-admin-secret

# 发卡平台 Webhook 密钥（对接微信/支付宝发卡软件时用）
FAKA_WEBHOOK_SECRET=your-faka-webhook-secret

# 启动时预置口令：口令:次数,口令:次数
INITIAL_CODES=TOPTALK-TEST:3,VIP-2024:10

# 数据库路径（Render 可挂载持久盘）
DATABASE_PATH=./data/toptalk.db
